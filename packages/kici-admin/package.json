{
  "name": "kici-admin",
  "version": "0.1.21",
  "description": "Administration CLI for a KiCI customer-deployable orchestrator. Manage runs, agents, peers, sources, secrets, event log, and database schema.",
  "keywords": [
    "ci",
    "cicd",
    "continuous-integration",
    "typescript",
    "workflow",
    "cli",
    "admin",
    "self-hosted",
    "orchestrator",
    "pipelines"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kici-dev/kici-public.git",
    "directory": "packages/kici-admin"
  },
  "bugs": "https://github.com/kici-dev/kici-public/issues",
  "homepage": "https://kici.dev",
  "author": {
    "name": "KiCI",
    "email": "hello@kici.dev"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "bin": {
    "kici-admin": "./bin/kici-admin.js",
    "kici-agent": "./bin/kici-agent.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm exec tsx ../../hack/generate-sbom.ts --package packages/kici-admin --name kici-admin"
  },
  "dependencies": {
    "@kici-dev/agent": "workspace:*",
    "@kici-dev/orchestrator": "workspace:*"
  },
  "files": [
    "bin",
    "sbom.spdx.json"
  ]
}
